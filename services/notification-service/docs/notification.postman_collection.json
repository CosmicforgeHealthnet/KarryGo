            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{customer_base_url}}/api/v1/customer/notifications/realtime-token",
              "host": ["{{customer_base_url}}"],
              "path": ["api", "v1", "customer", "notifications", "realtime-token"]
            }
          }
        },
        {
          "name": "POST /customer/notifications/devices",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
