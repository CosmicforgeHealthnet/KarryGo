# Notification Service
APP_ENV=development
HTTP_ADDR=:8106

# Notification-owned Postgres database.
NOTIFICATION_DATABASE_URL=postgres://cosmicforge_logistics:cosmicforge_logistics@localhost:5438/notification_service?sslmode=disable

# Notification-owned Redis instance or namespace.
NOTIFICATION_REDIS_ADDR=localhost:6385
NOTIFICATION_REDIS_PASSWORD=
NOTIFICATION_REDIS_DB=0

# Comma-separated service secrets, e.g. customer-service=secret,payment-wallet-service=secret
NOTIFICATION_SERVICE_SECRETS=customer-service=development-customer-notification-secret

# Firebase Cloud Messaging. Leave empty in local development to use the logging push sender.
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# cPanel email over SMTP. Leave credentials empty in local development to use the logging email sender.
NOTIFICATION_EMAIL_PROVIDER=smtp
NOTIFICATION_SMTP_HOST=
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USERNAME=
NOTIFICATION_SMTP_PASSWORD=
NOTIFICATION_SMTP_TLS_MODE=starttls
NOTIFICATION_EMAIL_FROM=

# Realtime websocket token signing.
NOTIFICATION_REALTIME_TOKEN_SECRET=development-notification-realtime-token-secret

# Worker and queue settings.
NOTIFICATION_WORKER_CONCURRENCY=5
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_REQUEST_STREAM=notification:requests
NOTIFICATION_DELIVERY_STREAM=notification:deliveries
NOTIFICATION_DEAD_LETTER_STREAM=notification:dead_letters
