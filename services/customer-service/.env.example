# Customer Service
APP_ENV=development
HTTP_ADDR=:8101
MIGRATION=false

# Customer-owned Postgres database.
CUSTOMER_DATABASE_URL=postgres://cosmicforge_logistics:cosmicforge_logistics@localhost:5433/customer_service?sslmode=disable

# Customer-owned Redis instance or namespace.
CUSTOMER_REDIS_ADDR=localhost:6380
CUSTOMER_REDIS_PASSWORD=
CUSTOMER_REDIS_DB=0

# Local development secrets only. Replace these in staging/production.
CUSTOMER_ACCESS_TOKEN_SECRET=development-customer-access-token-secret
CUSTOMER_REFRESH_TOKEN_SECRET=development-customer-refresh-token-secret
CUSTOMER_OTP_SECRET=development-customer-otp-secret

# Token and OTP timing.
CUSTOMER_ACCESS_TOKEN_TTL_SECONDS=900
CUSTOMER_REFRESH_TOKEN_TTL_HOURS=720
CUSTOMER_OTP_TTL_SECONDS=300
CUSTOMER_OTP_RATE_LIMIT_WINDOW_SECONDS=600

# OTP limits.
CUSTOMER_OTP_MAX_REQUESTS=5
CUSTOMER_OTP_MAX_ATTEMPTS=5

# Local-only debug mode. When true, OTPs can be exposed/logged for testing.
CUSTOMER_DEBUG_OTP=true

# ── Internal service clients ──────────────────────────────────────────────────
# Notification service (port 8106). Bare origin only — the client appends
# /api/v1/notifications/... itself, so do NOT include that path here.
# When unset, the /notifications proxy routes are skipped (no-op local dev).
CUSTOMER_NOTIFICATION_BASE_URL=http://localhost:8106
CUSTOMER_NOTIFICATION_SECRET=development-customer-notification-secret
