# Media/File Service
APP_ENV=development
HTTP_ADDR=:8109
MIGRATION=false

# Media-owned Postgres database.
MEDIA_FILE_DATABASE_URL=postgres://cosmicforge_logistics:cosmicforge_logistics@localhost:5441/media_file_service?sslmode=disable

# Firebase Storage.
MEDIA_FILE_FIREBASE_BUCKET=karrygo-dev-media.appspot.com
MEDIA_FILE_FIREBASE_CREDENTIALS_FILE=
MEDIA_FILE_FIREBASE_CREDENTIALS_JSON=
MEDIA_FILE_PUBLIC_BASE_URL=

# Upload limits.
MEDIA_FILE_MAX_UPLOAD_BYTES=26214400

# Internal service auth tokens. Use strong unique values outside local development.
MEDIA_FILE_SERVICE_TOKENS=customer-service=development-media-token,taxi-service=development-media-token,dispatch-delivery-service=development-media-token,hauling-service=development-media-token,verification-compliance-service=development-media-token
