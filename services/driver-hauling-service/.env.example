# Driver Hauling Service
APP_ENV=development
HTTP_ADDR=:8104

# Set to true to run database migrations on startup.
HAULING_MIGRATION=false

# ── Database ──────────────────────────────────────────────────────────────────
HAULING_DATABASE_URL=postgres://cosmicforge_logistics:cosmicforge_logistics@localhost:5436/hauling_service?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
HAULING_REDIS_ADDR=localhost:6383
HAULING_REDIS_PASSWORD=
HAULING_REDIS_DB=0

# ── Token secrets ─────────────────────────────────────────────────────────────
# Replace with long random strings in staging/production.
HAULING_PROVIDER_TOKEN_SECRET=development-hauling-provider-token-secret
HAULING_PROVIDER_REFRESH_SECRET=development-hauling-provider-refresh-secret
HAULING_PROVIDER_OTP_SECRET=development-hauling-provider-otp-secret

# Must match CUSTOMER_ACCESS_TOKEN_SECRET in customer-service.
HAULING_CUSTOMER_TOKEN_SECRET=development-customer-access-token-secret

# ── Token & OTP timing ────────────────────────────────────────────────────────
HAULING_ACCESS_TOKEN_TTL_SECONDS=3600
HAULING_REFRESH_TOKEN_TTL_DAYS=30
HAULING_OTP_TTL_SECONDS=600
HAULING_OTP_RATE_WINDOW_SECONDS=60
HAULING_OTP_MAX_REQUESTS=5
HAULING_OTP_MAX_ATTEMPTS=5

# Set to true in local dev to expose OTP codes in logs.
HAULING_OTP_DEBUG=false

# ── Internal service clients ──────────────────────────────────────────────────
HAULING_NOTIFICATION_URL=http://localhost:8106/api/v1/notifications
HAULING_NOTIFICATION_SECRET=development-hauling-notification-secret

HAULING_PAYMENT_URL=http://localhost:8105/api/v1/payment-wallet
HAULING_PAYMENT_SECRET=development-hauling-payment-secret

# ── Matching tuning ───────────────────────────────────────────────────────────
HAULING_BOOKING_MATCH_TIMEOUT=30
HAULING_PROVIDER_ONLINE_TTL=7200
