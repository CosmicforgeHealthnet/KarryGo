    {
      "name": "Webhook",
      "description": "Paystack webhook. Verified by HMAC-SHA512 over the RAW request body using the Paystack secret key (x-paystack-signature). The pre-request script signs the raw body with {{paystack_secret_key}}. The route must stay un-proxied and un-rewritten so the body is byte-for-byte identical.",
      "item": [
        {
          "name": "POST /webhooks/paystack",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Sign the raw body with HMAC-SHA512 using the Paystack secret key, matching Paystack's webhook signature.",
                  "var secret = pm.variables.replaceIn('{{paystack_secret_key}}');",
                  "var rawBody = '';",
                  "if (pm.request.body && pm.request.body.mode === 'raw' && pm.request.body.raw) {",
                  "    rawBody = pm.variables.replaceIn(pm.request.body.raw);",
                  "}",
                  "var signature = CryptoJS.HmacSHA512(rawBody, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'x-paystack-signature', value: signature });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"charge.success\",\n  \"data\": {\n    \"reference\": \"paystack-reference\",\n    \"amount\": 100000,\n    \"currency\": \"NGN\",\n    \"status\": \"success\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}{{api_base}}/webhooks/paystack",
              "host": ["{{base_url}}{{api_base}}"],
              "path": ["webhooks", "paystack"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
