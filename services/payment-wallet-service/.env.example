# Payment & Wallet Service — local configuration template.
# Copy to `.env` and fill in real values. `.env` is git-ignored; never commit secrets.

APP_ENV=development
HTTP_ADDR=:8105

# Postgres / Redis (defaults match infra/docker-compose.yml and the local bootstrap).
PAYMENT_WALLET_DATABASE_URL=postgres://cosmicforge_logistics:cosmicforge_logistics@localhost:5437/payment_wallet_service?sslmode=disable
PAYMENT_WALLET_REDIS_ADDR=localhost:6384
PAYMENT_WALLET_REDIS_PASSWORD=
PAYMENT_WALLET_REDIS_DB=0

# Auth secrets. Provider secrets must match each provider service's access-token
# secret (e.g. hauling mirrors HAULING_PROVIDER_TOKEN_SECRET).
PAYMENT_WALLET_CUSTOMER_ACCESS_TOKEN_SECRET=development-customer-access-token-secret
PAYMENT_WALLET_PROVIDER_ACCESS_TOKEN_SECRETS=taxi=development-taxi-access-token-secret,dispatch=development-dispatch-access-token-secret,hauling=development-hauling-provider-token-secret
PAYMENT_WALLET_SERVICE_SECRETS=taxi-service=development-payment-wallet-service-secret,dispatch-delivery-service=development-payment-wallet-service-secret,hauling-service=development-payment-wallet-service-secret,admin-backoffice-service=development-payment-wallet-service-secret

# Paystack. Use test keys from your Paystack dashboard (https://dashboard.paystack.com/#/settings/developers).
PAYMENT_WALLET_PAYSTACK_BASE_URL=https://api.paystack.co
PAYMENT_WALLET_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMENT_WALLET_PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Business rules.
PAYMENT_WALLET_PLATFORM_FEE_BPS=1500
PAYMENT_WALLET_HTTP_TIMEOUT_SECONDS=15
PAYMENT_WALLET_WEBHOOK_MAX_SKEW_SECONDS=300
PAYMENT_WALLET_WITHDRAWAL_MIN_KOBO=10000
PAYMENT_WALLET_WITHDRAWAL_MAX_KOBO=500000000
PAYMENT_WALLET_REQUIRE_MANUAL_PAYOUTS=true
PAYMENT_WALLET_DEFAULT_CURRENCY=NGN

# Public base URL Paystack redirects back to after checkout (set to a reachable URL when testing top-ups).
PAYMENT_WALLET_PUBLIC_CALLBACK_BASE_URL=http://localhost:8105
