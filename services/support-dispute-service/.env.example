# support-dispute-service — local config template. Copy to .env and adjust.

APP_ENV=development
HTTP_ADDR=:8107

# Run migrations (001–005) on startup.
MIGRATION=false

SUPPORT_DISPUTE_DATABASE_URL=postgres://cosmicforge_logistics:cosmicforge_logistics@localhost:5439/support_dispute_service?sslmode=disable

# ── Bearer token secrets (must match each issuing service) ───────────────────
SUPPORT_DISPUTE_CUSTOMER_ACCESS_TOKEN_SECRET=development-customer-access-token-secret
SUPPORT_DISPUTE_HAULING_PROVIDER_TOKEN_SECRET=development-hauling-provider-token-secret
SUPPORT_DISPUTE_TAXI_PROVIDER_TOKEN_SECRET=development-taxi-provider-token-secret
SUPPORT_DISPUTE_DISPATCH_PROVIDER_TOKEN_SECRET=development-dispatch-provider-token-secret

# ── Inbound admin/internal HMAC callers (service=secret, comma-separated) ─────
SUPPORT_DISPUTE_SERVICE_SECRETS=customer-service=development-support-dispute-service-secret,taxi-service=development-support-dispute-service-secret,dispatch-delivery-service=development-support-dispute-service-secret,hauling-service=development-support-dispute-service-secret,admin-backoffice-service=development-support-dispute-service-secret

# ── Outbound clients (BARE ORIGIN only). Empty disables the feature. ─────────
# Notifications (status/chat/dispute/SOS pushes + realtime chat proxy).
SUPPORT_DISPUTE_NOTIFICATION_URL=
SUPPORT_DISPUTE_NOTIFICATION_SECRET=development-support-dispute-notification-secret
# Payment-wallet (admin-driven dispute refunds). Bare origin, signs as support-dispute-service.
SUPPORT_DISPUTE_PAYMENT_URL=
SUPPORT_DISPUTE_PAYMENT_SECRET=development-support-dispute-payment-secret

# ── Owning-service identity lookups (BARE ORIGIN). Empty disables enrichment. ─
# The shared secret must be trusted by the owning service's *_SERVICE_SECRETS
# under the name "support-dispute-service".
SUPPORT_DISPUTE_CUSTOMER_SERVICE_URL=
SUPPORT_DISPUTE_CUSTOMER_SERVICE_SECRET=development-support-dispute-service-secret
SUPPORT_DISPUTE_HAULING_SERVICE_URL=
SUPPORT_DISPUTE_HAULING_SERVICE_SECRET=development-support-dispute-service-secret
SUPPORT_DISPUTE_TAXI_SERVICE_URL=
SUPPORT_DISPUTE_TAXI_SERVICE_SECRET=development-support-dispute-service-secret
SUPPORT_DISPUTE_DISPATCH_SERVICE_URL=
SUPPORT_DISPUTE_DISPATCH_SERVICE_SECRET=development-support-dispute-service-secret
