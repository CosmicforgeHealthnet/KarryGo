          "request": {
            "method": "GET",
            "header": [],
            "description": "List/filter disputes for adjudication. Filters (optional): outcome, service_type.",
            "url": {
              "raw": "{{base_url}}{{api_base}}/admin/disputes?outcome=pending&limit=50&offset=0",
