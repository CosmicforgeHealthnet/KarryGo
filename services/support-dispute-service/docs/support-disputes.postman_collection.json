          }
        },
        {
          "name": "POST /provider/complaints/:id/messages/read",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Mark admin replies as read on the provider's complaint.",
