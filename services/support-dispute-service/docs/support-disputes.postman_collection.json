            "description": "Resolve a dispute. outcome = favour_complainant|favour_respondent|split|dismissed. Optional refund (only honoured when outcome favours the complainant/split and payment-wallet is configured): refund_amount_kobo + refund_source_reference (the original payment reference).",
            "body": { "mode": "raw", "raw": "{\n  \"outcome\": \"favour_complainant\",\n  \"note\": \"Damage confirmed from the photos.\",\n  \"refund_amount_kobo\": 500000,\n  \"refund_source_reference\": \"pay-ref-abc123\"\n}" },
            "url": { "raw": "{{base_url}}{{api_base}}/admin/disputes/{{dispute_id}}/resolve", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "disputes", "{{dispute_id}}", "resolve"] }
          }
        },
        {
          "name": "POST /admin/complaints/:id/messages",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Admin-ID", "value": "admin-1" }],
            "description": "Reply to a complainant in the chat as admin (notifies them; pushed live when notification-service is configured).",
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Thanks for the details — we are processing your refund.\"\n}" },
            "url": { "raw": "{{base_url}}{{api_base}}/admin/complaints/{{complaint_id}}/messages", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "complaints", "{{complaint_id}}", "messages"] }
          }
        },
        {
          "name": "GET /admin/complaints/:id/messages",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Read the full chat thread for a complaint (admin).",
            "url": { "raw": "{{base_url}}{{api_base}}/admin/complaints/{{complaint_id}}/messages", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "complaints", "{{complaint_id}}", "messages"] }
          }
        }
      ]
    },
    {
      "name": "Realtime proxy (bearer)",
      "description": "Live-chat support via notification-service. Only registered when SUPPORT_DISPUTE_NOTIFICATION_URL is set. Customer group shown; providers use /provider/notifications (+ /taxi-provider, /dispatch-provider).",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customer_token}}", "type": "string" }] },
      "item": [
        {
          "name": "GET /customer/notifications",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Recent notification feed for the authenticated customer.",
            "url": {
              "raw": "{{base_url}}{{api_base}}/customer/notifications?limit=50",
              "host": ["{{base_url}}{{api_base}}"],
              "path": ["customer", "notifications"],
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
