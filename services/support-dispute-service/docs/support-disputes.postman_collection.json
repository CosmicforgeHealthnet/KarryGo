            "url": { "raw": "{{base_url}}{{api_base}}/provider/complaints/{{complaint_id}}/messages/read", "host": ["{{base_url}}{{api_base}}"], "path": ["provider", "complaints", "{{complaint_id}}", "messages", "read"] }
          }
        },
        {
          "name": "POST /provider/sos",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Provider emergency SOS (e.g. unsafe situation mid-trip).",
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Vehicle breakdown in an unsafe area\",\n  \"lat\": 6.5244,\n  \"lng\": 3.3792\n}" },
            "url": { "raw": "{{base_url}}{{api_base}}/provider/sos", "host": ["{{base_url}}{{api_base}}"], "path": ["provider", "sos"] }
          }
        }
      ]
    },
    {
      "name": "Admin (HMAC)",
      "description": "Back-office endpoints. Requests are signed automatically by the folder pre-request script using {{service_name}} / {{service_secret}} (shared/go/serviceauth: HMAC-SHA256 over METHOD\\nrequestURI\\ntimestamp\\nsha256hex(body)). The service_name must be present in SUPPORT_DISPUTE_SERVICE_SECRETS.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Reproduces shared/go/serviceauth signing so admin endpoints accept the request.",
              "var serviceName = pm.variables.replaceIn('{{service_name}}');",
              "var serviceSecret = pm.variables.replaceIn('{{service_secret}}');",
              "if (!serviceName || !serviceSecret) {",
              "    console.warn('service_name / service_secret not set; admin request will fail HMAC auth.');",
              "}",
              "var rawUrl = pm.variables.replaceIn(pm.request.url.toString());",
              "var noScheme = rawUrl.replace(/^[a-zA-Z]+:\\/\\//, '');",
              "var slash = noScheme.indexOf('/');",
              "var requestURI = slash === -1 ? '/' : noScheme.substring(slash);",
              "var rawBody = '';",
              "if (pm.request.body && pm.request.body.mode === 'raw' && pm.request.body.raw) {",
              "    rawBody = pm.variables.replaceIn(pm.request.body.raw);",
              "}",
              "var timestamp = Math.floor(Date.now() / 1000).toString();",
              "var bodyHash = CryptoJS.SHA256(rawBody).toString(CryptoJS.enc.Hex);",
              "var canonical = pm.request.method.toUpperCase() + '\\n' + requestURI + '\\n' + timestamp + '\\n' + bodyHash;",
              "var signature = CryptoJS.HmacSHA256(canonical, serviceSecret).toString(CryptoJS.enc.Hex);",
              "pm.request.headers.upsert({ key: 'X-Service-Name', value: serviceName });",
              "pm.request.headers.upsert({ key: 'X-Service-Timestamp', value: timestamp });",
              "pm.request.headers.upsert({ key: 'X-Service-Signature', value: signature });"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "GET /admin/complaints",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Triage queue. List/filter complaints. Emergencies sort to the top. Filters (all optional): status, priority (normal|high|emergency), service_type, complainant_type.",
            "url": {
              "raw": "{{base_url}}{{api_base}}/admin/complaints?status=open&limit=50&offset=0",
              "host": ["{{base_url}}{{api_base}}"],
              "path": ["admin", "complaints"],
              "query": [
                { "key": "status", "value": "open" },
                { "key": "priority", "value": "", "disabled": true },
                { "key": "service_type", "value": "", "disabled": true },
                { "key": "complainant_type", "value": "", "disabled": true },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "GET /admin/complaints/:id",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Review one complaint (admin bypasses ownership). Includes the resolved complainant_name/phone identity snapshot.",
            "url": { "raw": "{{base_url}}{{api_base}}/admin/complaints/{{complaint_id}}", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "complaints", "{{complaint_id}}"] }
          }
        },
        {
          "name": "GET /admin/complaints/:id/evidence",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Review the evidence attached to a complaint (admin).",
            "url": { "raw": "{{base_url}}{{api_base}}/admin/complaints/{{complaint_id}}/evidence", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "complaints", "{{complaint_id}}", "evidence"] }
          }
        },
        {
          "name": "GET /admin/complaints/:id/dispute",
          "request": {
            "method": "GET",
            "header": [],
            "description": "View the dispute linked to a complaint (admin).",
            "url": { "raw": "{{base_url}}{{api_base}}/admin/complaints/{{complaint_id}}/dispute", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "complaints", "{{complaint_id}}", "dispute"] }
          }
        },
        {
          "name": "GET /admin/complaints/:id/events",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Read the audit trail for a complaint (complaint_created, status_changed, evidence_added, escalated, dispute_resolved, sos_raised).",
            "url": { "raw": "{{base_url}}{{api_base}}/admin/complaints/{{complaint_id}}/events", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "complaints", "{{complaint_id}}", "events"] }
          }
        },
        {
          "name": "POST /admin/complaints/:id/refresh-identity",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Re-pull the complainant's name/phone snapshot from the owning service (used when the original lookup was empty / is stale).",
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}{{api_base}}/admin/complaints/{{complaint_id}}/refresh-identity", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "complaints", "{{complaint_id}}", "refresh-identity"] }
          }
        },
        {
          "name": "PUT /admin/complaints/:id/status",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Admin-ID", "value": "admin-1" }],
            "description": "Change a complaint's status and notify the complainant. status = open|under_review|awaiting_evidence|resolved|closed|escalated. resolution_note is optional. X-Admin-ID identifies the actor in the audit trail.",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"under_review\",\n  \"resolution_note\": \"Investigating with the provider.\"\n}" },
            "url": { "raw": "{{base_url}}{{api_base}}/admin/complaints/{{complaint_id}}/status", "host": ["{{base_url}}{{api_base}}"], "path": ["admin", "complaints", "{{complaint_id}}", "status"] }
          }
        },
