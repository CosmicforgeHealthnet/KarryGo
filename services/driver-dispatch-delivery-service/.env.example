APP_ENV=development
SERVICE_NAME=driver-dispatch-delivery-service
GIN_MODE=debug
HTTP_ADDR=:8103

DISPATCH_DELIVERY_DATABASE_URL=postgres://cosmicforge_logistics:cosmicforge_logistics@driver-dispatch-delivery-postgres:5432/dispatch_delivery_service?sslmode=disable

DISPATCH_DELIVERY_REDIS_ADDR=driver-dispatch-delivery-redis:6379
DISPATCH_DELIVERY_REDIS_PASSWORD=
DISPATCH_DELIVERY_REDIS_DB=0
DISPATCH_DELIVERY_INTERNAL_SERVICE_KEY=development-internal-service-key
AVAILABILITY_SERVICE_URL=http://localhost:8103
BROADCAST_INITIAL_RADIUS_KM=5.0
BROADCAST_RADIUS_INCREMENT_KM=3.0
BROADCAST_MAX_ATTEMPTS=3
BROADCAST_WINDOW_SECONDS=30

# -- Wallet Service Integration ----------------------------------------------
# Base URL of payment-wallet-service
# Local: http://localhost:8105/api/v1/payment-wallet
# VPS:   http://{vps-internal-ip}:8105/api/v1/payment-wallet
WALLET_SERVICE_URL=http://localhost:8105/api/v1/payment-wallet

# HMAC secret for service-to-service auth.
# The dispatch-delivery-service entry in payment-wallet-service's
# PAYMENT_WALLET_SERVICE_SECRETS must use the same value.
WALLET_SERVICE_SECRET=replace-with-strong-random-secret-min-32-chars

# Source service identifier used in internal wallet API calls. Do not change.
WALLET_SERVICE_SOURCE=dispatch-delivery-service

# Firebase FCM delivery is integrated through the request notification interface.
# FIREBASE_PROJECT_ID=
# FIREBASE_CREDENTIALS_PATH=

VERIFICATION_STORAGE_MODE=local_private
VERIFICATION_UPLOAD_ROOT=/app/uploads
# VERIFICATION_STORAGE_BASE_URL is optional; set it only when stored files are exposed through a storage URL.
# VERIFICATION_STORAGE_BASE_URL=

# Must match the dispatch entry in payment-wallet-service:
# PAYMENT_WALLET_PROVIDER_ACCESS_TOKEN_SECRETS=dispatch:<same-value>
DISPATCH_RIDER_ACCESS_TOKEN_SECRET=replace-with-strong-random-secret-min-32-chars
DISPATCH_RIDER_REFRESH_TOKEN_SECRET=replace-with-strong-random-secret-min-32-chars
DISPATCH_RIDER_OTP_SECRET=replace-with-strong-random-secret-min-32-chars

DISPATCH_RIDER_JWT_ACCESS_TTL_MINUTES=15
DISPATCH_RIDER_JWT_REFRESH_TTL_DAYS=30

DISPATCH_RIDER_OTP_TTL_MINUTES=10
DISPATCH_RIDER_OTP_MAX_ATTEMPTS=3
DISPATCH_RIDER_OTP_LOCKOUT_MINUTES=30
DISPATCH_RIDER_OTP_RATE_LIMIT_MAX=3
DISPATCH_RIDER_OTP_RATE_LIMIT_WINDOW_MINUTES=10
DISPATCH_RIDER_DEBUG_OTP=true

# -- Email OTP Delivery (optional) -------------------------------------------
# When SMTP_HOST is set, the same OTP code is also sent to the user's email.
# Leave SMTP_HOST empty to disable email delivery (SMS-only mode stays active).
# Port 465 = implicit TLS (cPanel/Exim default). Port 587 = STARTTLS.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
